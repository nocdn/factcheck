# Server
# Port the API listens on.
PORT=7110

# Rate limiting (main)
# Time window in milliseconds for the /api/check global rate limit.
RATE_LIMIT_WINDOW_MS=86400000
# Maximum number of /api/check requests allowed during the main rate limit window.
RATE_LIMIT_MAX=20

# Rate limiting (health check)
# Time window in milliseconds for the /api/health global rate limit.
HEALTH_RATE_LIMIT_WINDOW_MS=500
# Maximum number of requests allowed during the /api/health rate limit window.
HEALTH_RATE_LIMIT_MAX=1

# Gemini
# API key for the Gemini Developer API.
GEMINI_API_KEY=
# Default Gemini model used when the request body omits model.
GEMINI_MODEL=gemini-3-flash-preview
# Default effort used when the request body omits effort.
# Supported values for the allowed Gemini 3 models are: minimal, low, medium, high.
EFFORT=high
# Number of times to retry a Gemini request when the model reports temporary high demand.
GEMINI_HIGH_DEMAND_RETRY_COUNT=2
# Delay in milliseconds before retrying a Gemini high-demand response.
GEMINI_HIGH_DEMAND_RETRY_DELAY_MS=10000

# OpenAI
# API key for OpenAI Responses API fact-checking.
OPENAI_API_KEY=
# Default OpenAI model used when provider=openai and the request body omits model.
OPENAI_MODEL=gpt-5.5
# Default OpenAI effort used when provider=openai and the request body omits effort.
OPENAI_EFFORT=medium

# Provider model requests
# Timeout in milliseconds for each Google provider model request.
GEMINI_TIMEOUT_MS=300000
# Timeout in milliseconds for each OpenAI provider model request.
OPENAI_TIMEOUT_MS=300000
# Delay in milliseconds before the final provider synthesis request after search planning and Exa search complete.
GEMINI_STEP_DELAY_MS=10000
# Maximum number of output tokens requested from the selected provider for the final fact-check.
MAX_OUTPUT_TOKENS=32768
# Maximum number of output tokens requested from the selected provider when planning Exa searches.
SEARCH_PLAN_MAX_OUTPUT_TOKENS=2048

# Exa
# API key for Exa search, used to retrieve full-text web evidence before the final fact-check.
EXA_API_KEY=
# Exa search type to use for generated queries.
EXA_SEARCH_TYPE=auto
# Maximum Exa search queries the selected provider may generate for social/video URL fact-checks. Clamped from 1 to 10.
SOCIALS_MAX_SEARCHES=5
# Number of Exa full-text results to retrieve for each social/video search. Clamped from 1 to 10.
SOCIALS_RESULTS_PER_SEARCH=5
# Maximum Exa search queries the selected provider may generate for transcript fact-checks. Clamped from 1 to 20.
YOUTUBE_MAX_SEARCHES=10
# Number of Exa full-text results to retrieve for each YouTube search. Clamped from 1 to 10.
YOUTUBE_RESULTS_PER_SEARCH=3
# Maximum Exa search queries the selected provider may generate for article/webpage fact-checks. Clamped from 1 to 10.
ARTICLE_MAX_SEARCHES=7
# Number of Exa full-text results to retrieve for each article/webpage search. Clamped from 1 to 10.
ARTICLE_RESULTS_PER_SEARCH=4
# Maximum full-text characters to pass to the selected provider per Exa result or source webpage.
EXA_SEARCH_TEXT_MAX_CHARACTERS=35000
# Timeout in milliseconds for each Exa search request.
EXA_SEARCH_TIMEOUT_MS=60000

# Cohere (YouTube transcript fact-check)
# API key for Cohere, used to transcribe audio for YouTube fact-checks.
COHERE_API_KEY=
# Cohere transcription model used for YouTube audio.
COHERE_TRANSCRIBE_MODEL=cohere-transcribe-03-2026
# ISO-639-1 language code passed to Cohere transcription.
COHERE_TRANSCRIBE_LANGUAGE=en
# Timeout in milliseconds for the Cohere transcription request.
COHERE_TRANSCRIBE_TIMEOUT_MS=300000
# audioQuality preset or bitrate forwarded to videos.bartoszbak.org for YouTube audio downloads.
# Accepts named presets (best, high, medium, low, lowest) or raw bitrate strings (for example 96K, 128K, 192K).
# Defaults to a lower-bitrate preset so most YouTube videos fit under Cohere's 25 MB upload limit.
YOUTUBE_AUDIO_QUALITY=low

# Video download
# Download endpoint used to fetch the source video (or audio for YouTube) before fact-checking.
VIDEO_DOWNLOAD_API_URL=https://videos.bartoszbak.org/api/download
# Default download quality used when the request body omits quality.
FACT_CHECK_DEFAULT_QUALITY=1080p
# Timeout in milliseconds for the upstream video or audio download request.
VIDEO_DOWNLOAD_TIMEOUT_MS=120000

# Retries for upstream services (Exa and video downloader)
# Number of retries when Exa returns a retryable status (429, 502, 503, 504).
EXA_RETRY_COUNT=2
# Delay in milliseconds between Exa retries.
EXA_RETRY_DELAY_MS=5000
# Number of retries when the video downloader returns a retryable status.
DOWNLOADER_RETRY_COUNT=2
# Delay in milliseconds between video downloader retries.
DOWNLOADER_RETRY_DELAY_MS=5000

# Direct mode end-to-end timeout
# Maximum time in milliseconds a direct (non-queued) /api/check request may run before the server aborts it.
DIRECT_MODE_TIMEOUT_MS=600000

# Retries for Cohere transcription
# Number of retries when Cohere returns a retryable status (429, 502, 503, 504).
COHERE_RETRY_COUNT=2
# Delay in milliseconds between Cohere retries.
COHERE_RETRY_DELAY_MS=5000

# Inline video safety
# Maximum downloaded video size in bytes allowed before the API refuses to send the video inline to Gemini.
# Keep this below Gemini's inline request size guidance unless you intentionally change the transport strategy.
INLINE_VIDEO_MAX_BYTES=18874368
# Maximum downloaded YouTube audio size in bytes allowed before the API refuses to forward it to Cohere for transcription.
# Cohere's audio transcription endpoint rejects uploads above 25 MB, so keep this at or below 26214400.
YOUTUBE_AUDIO_MAX_BYTES=26214400
